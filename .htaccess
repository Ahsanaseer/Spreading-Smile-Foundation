RewriteEngine On

# Redirect from .html to clean URL (optional but SEO friendly)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^\s]+)\.html\sHTTP/
RewriteRule ^([^\s]+)\.html$ /$1 [R=301,L]

# Internally map clean URLs to .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.html [L]
