RewriteEngine On

# Cache Control for HTML, CSS, JS, and Images - Prevents browser caching
<FilesMatch "\.(html|htm|css|js|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>


# Redirect URLs with .html to extensionless (keep query strings)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^\s]+)\.html(\?[^\s]*)?\sHTTP/
RewriteRule ^([^\s]+)\.html$ /$1 [R=301,L]

# Internally serve .html files when accessed without extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.html [L]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
